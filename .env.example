# Copy this file to .env on the production host and replace every example value.
# Do not commit .env or reuse Django/Jackrabbit/hosting passwords.

# Public hostname used by Caddy and Django security checks. DOMAIN and
# ALLOWED_HOSTS are bare hostnames without https:// or a path. The CSRF origin
# includes https:// and must not have a path.
DOMAIN=gyminators.example.com
ALLOWED_HOSTS=gyminators.example.com
CSRF_TRUSTED_ORIGINS=https://gyminators.example.com

# Internal PostgreSQL database. Replace all examples and use a unique randomly
# generated password that is not reused for Django, hosting, or Jackrabbit.
POSTGRES_DB=gyminators
POSTGRES_USER=gyminators
POSTGRES_PASSWORD=replace-with-a-long-random-password

# Generate a unique value of at least 50 characters. This is not a login password.
DJANGO_SECRET_KEY=replace-with-at-least-50-random-characters
DJANGO_DEBUG=false

# Limited non-financial Jackrabbit reporting. The webhook token is a new secret
# generated by Gyminators for Zapier to call this website. It is NOT the
# Jackrabbit Zapier API key and must not be entered into Jackrabbit. Event intake
# remains safely unavailable while the token below is blank.
JACKRABBIT_REPORTING_ENABLED=true
JACKRABBIT_ORG_ID=154877
JACKRABBIT_WEBHOOK_TOKEN=
# Keep blank normally. During rotation, place the former token here until all
# nine Zaps use the new current token, then remove it.
JACKRABBIT_WEBHOOK_PREVIOUS_TOKEN=
JACKRABBIT_WEBHOOK_MAX_BODY_BYTES=32768
JACKRABBIT_CLASS_SYNC_TIMEOUT_SECONDS=15
JACKRABBIT_CLASS_STALE_AFTER_MINUTES=60
JACKRABBIT_CLASS_SYNC_INTERVAL_SECONDS=900
